# SentinelAI — local dev (no Docker). Install services natively on your machine.

# PostgreSQL (required)
DATABASE_URL=postgresql+asyncpg://sentinel:sentinel@localhost:5432/sentinelai

# Redis (required for Celery workers; API runs without it using background tasks)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
USE_CELERY=false

# Neo4j (required for knowledge graph — falls back to in-memory if unreachable)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=sentinelai

# AI / LLM
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.3
GEMINI_API_KEY=

# OSINT (optional)
SERPAPI_KEY=
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=

# App
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
